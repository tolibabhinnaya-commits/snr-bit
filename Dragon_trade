def validasi_entry_relevan(exchange, sinyal: dict):
    """
    [FIX 3] Cek apakah entry price masih relevan vs harga pasar SAAT INI.
    BUY  -> valid jika harga belum lebih dari ENTRY_TOLERANSI_PCT di atas entry.
    SELL -> valid jika harga belum lebih dari ENTRY_TOLERANSI_PCT di bawah entry.
    Fail-open: jika gagal fetch ticker, sinyal tetap dikirim.
    Return: (valid: bool, keterangan: str)
    """
    try:
        harga = exchange.fetch_ticker(sinyal["symbol"])["last"]
        entry = sinyal["entry"]
        diff  = (harga - entry) / entry * 100  # positif = harga > entry
        if sinyal["arah"] == "BUY" and diff > ENTRY_TOLERANSI_PCT:
            return False, f"Entry TERLEWAT — harga {harga:.6f} sudah {diff:.2f}% di atas entry {entry:.6f}"
        if sinyal["arah"] == "SELL" and diff < -ENTRY_TOLERANSI_PCT:
            return False, f"Entry TERLEWAT — harga {harga:.6f} sudah {abs(diff):.2f}% di bawah entry {entry:.6f}"
        return True, f"Entry RELEVAN — harga: {harga:.6f}, entry: {entry:.6f}, diff: {diff:+.2f}%"
    except Exception as e:
        return True, f"[!] Tidak bisa cek harga ({e}) — sinyal dikirim tanpa validasi harga"


