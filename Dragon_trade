def _cari_bias_di_waktu(df_struktur_full, waktu_batas):
    w = df_struktur_full[df_struktur_full["timestamp"] <= waktu_batas].tail(JUMLAH_CANDLE_STRUKTUR)
    if len(w) < JUMLAH_CANDLE_STRUKTUR: return None, None, None, None
    w = w.reset_index(drop=True)
    df_s = deteksi_swing(w); poin = klasifikasi_struktur(ambil_urutan_swing(df_s))
    bias, lh, ll = tentukan_bias(poin)
    return bias, (bangun_zona_snr(df_s, bias, lh, ll) if bias != "sideways" else None), lh, ll


def backtest_symbol(exchange, symbol, total_candle_entry=BACKTEST_CANDLE_ENTRY_TOTAL,
                     max_lookahead=BACKTEST_MAX_LOOKAHEAD, verbose=True):
    if verbose: print(f"\n[Backtest] Mengambil data historis untuk {symbol} ...")
    df_entry_full    = ambil_ohlcv_banyak(exchange, symbol, TF_ENTRY, total_candle_entry)
    n_struct         = int(total_candle_entry * 1.2) // 4 + JUMLAH_CANDLE_STRUKTUR + 20
    df_struktur_full = ambil_ohlcv_banyak(exchange, symbol, TF_STRUKTUR, n_struct)
    trades, i, n     = [], JUMLAH_CANDLE_ENTRY, len(df_entry_full)
    while i < n:
        wkt = df_entry_full.iloc[i]["timestamp"]
        bias, zona, lh, ll = _cari_bias_di_waktu(df_struktur_full, wkt)
        if bias in (None, "sideways") or zona is None: i += 1; continue
        dew = df_entry_full[df_entry_full["timestamp"] <= wkt].tail(JUMLAH_CANDLE_ENTRY)
        if len(dew) < JUMLAH_CANDLE_ENTRY: i += 1; continue
        dew = dew.reset_index(drop=True)
        ob = cari_order_block(dew, zona, bias)
        if ob is None: i += 1; continue
        buf = SL_BUFFER_PCT / 100
        if bias == "bullish": entry,sl,tp,arah = ob["high"],ob["low"]*(1-buf),zona["resistance"]["high"],"BUY"
        else:                 entry,sl,tp,arah = ob["low"],ob["high"]*(1+buf),zona["support"]["low"],"SELL"
        rr = round(abs(tp-entry)/abs(entry-sl), 2) if abs(entry-sl) > 0 else 0
        if rr < MIN_RR: i += 1; continue
        hasil, idx_s = "TIMEOUT", min(i+max_lookahead, n-1)
        for j in range(i+1, min(i+1+max_lookahead, n)):
            r = df_entry_full.iloc[j]
            sl_hit = r["low"]<=sl  if arah=="BUY" else r["high"]>=sl
            tp_hit = r["high"]>=tp if arah=="BUY" else r["low"]<=tp
            if sl_hit: hasil="LOSS"; idx_s=j; break
            if tp_hit: hasil="WIN";  idx_s=j; break
        trades.append({"symbol":symbol,"waktu_entry":wkt,"bias":bias,"arah":arah,
                        "entry":round(entry,6),"sl":round(sl,6),"tp":round(tp,6),"rr":rr,"hasil":hasil})
        i = idx_s + 1
    return rangkum_backtest(symbol, trades)


def rangkum_backtest(symbol, trades):
    w,l,t = (sum(1 for x in trades if x["hasil"]==k) for k in ("WIN","LOSS","TIMEOUT"))
    s = w+l
    return {"symbol":symbol,"total_sinyal":len(trades),"win":w,"loss":l,"timeout":t,
            "winrate_pct":round(w/s*100,2) if s else 0,
            "avg_rr":round(sum(x["rr"] for x in trades)/len(trades),2) if trades else 0,
            "expectancy_r":round(sum((x["rr"] if x["hasil"]=="WIN" else -1) for x in trades if x["hasil"] in ("WIN","LOSS"))/s,2) if s else 0,
            "trades":trades}


def format_ringkasan_backtest(r):
    return (f"\n===== HASIL BACKTEST: {r['symbol']} =====\n"
            f"Total sinyal (VALID, RR>={MIN_RR}) : {r['total_sinyal']}\n"
            f"Menang (TP kena)                   : {r['win']}\n"
            f"Kalah (SL kena)                    : {r['loss']}\n"
            f"Timeout                            : {r['timeout']}\n"
            f"Win rate (dari yg selesai)         : {r['winrate_pct']}%\n"
            f"Rata-rata RR sinyal                : 1:{r['avg_rr']}\n"
            f"Expectancy per trade               : {r['expectancy_r']} R\n")


def jalankan_backtest(exchange):
    print("="*70); print("MEMULAI BACKTEST — hanya simulasi historis, BUKAN jaminan hasil ke depan."); print("="*70)
    semua = []
    for symbol in SYMBOLS:
        try:
            r = backtest_symbol(exchange, symbol); semua.append(r); print(format_ringkasan_backtest(r))
            if r["trades"]:
                print("Contoh 5 trade terakhir:")
                for t in r["trades"][-5:]:
                    print(f"  {t['waktu_entry']} | {t['arah']} | entry={t['entry']} sl={t['sl']} tp={t['tp']} rr=1:{t['rr']} -> {t['hasil']}")
        except Exception as e: print(f"[!] Error backtest {symbol}: {e}")
    if semua:
        tw=sum(r["win"] for r in semua); tl=sum(r["loss"] for r in semua); ts=tw+tl
        print("="*70); print(f"GABUNGAN -> Win:{tw} | Loss:{tl} | Winrate:{round(tw/ts*100,2) if ts else 0}%"); print("="*70)


