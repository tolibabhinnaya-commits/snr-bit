def _muat_cache() -> dict:
    """Muat cache sinyal dari file JSON lokal."""
    if not SIGNAL_CACHE_FILE.exists():
        return {}
    try:
        return json.loads(SIGNAL_CACHE_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _simpan_cache(cache: dict) -> None:
    """Simpan cache sinyal ke file JSON lokal."""
    try:
        SIGNAL_CACHE_FILE.write_text(json.dumps(cache, indent=2, default=str), encoding="utf-8")
    except Exception as e:
        print(f"[!] Tidak bisa simpan cache sinyal: {e}")


def sinyal_sudah_dikirim(sinyal: dict) -> bool:
    """
    [FIX 2] Cek duplikasi sinyal.
    Return True  -> sinyal sudah pernah dikirim -> SKIP.
    Return False -> sinyal baru -> tandai terkirim, lanjutkan.
    Key: hash dari (symbol + arah + waktu OB).
    """
    ob_time  = str(sinyal["order_block"].get("time", ""))
    key_str  = f"{sinyal['symbol']}_{sinyal['arah']}_{ob_time}"
    sig_hash = hashlib.md5(key_str.encode()).hexdigest()

    cache = _muat_cache()
    now   = datetime.now(timezone.utc).timestamp()
    ttl   = SIGNAL_CACHE_TTL_JAM * 3600

    # Bersihkan entri expired
    cache = {k: v for k, v in cache.items() if now - v < ttl}

    if sig_hash in cache:
        _simpan_cache(cache)
        return True  # duplikat

    cache[sig_hash] = now
    _simpan_cache(cache)
    return False


