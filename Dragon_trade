def deteksi_swing(df, order=SWING_ORDER):
    df    = df.copy()
    df["swing_high"] = False
    df["swing_low"]  = False
    highs = df["high"].values
    lows  = df["low"].values
    n     = len(df)
    for i in range(order, n - order):
        window_high = highs[i - order:i + order + 1]
        window_low  = lows[i - order:i + order + 1]
        if highs[i] == window_high.max() and np.argmax(window_high) == order:
            df.iat[i, df.columns.get_loc("swing_high")] = True
        if lows[i] == window_low.min() and np.argmin(window_low) == order:
            df.iat[i, df.columns.get_loc("swing_low")] = True
    return df


def ambil_urutan_swing(df):
    poin = []
    for i, row in df.iterrows():
        if row["swing_high"]:
            poin.append({"idx": i, "time": row["timestamp"], "harga": row["high"], "tipe": "high"})
        if row["swing_low"]:
            poin.append({"idx": i, "time": row["timestamp"], "harga": row["low"],  "tipe": "low"})
    poin.sort(key=lambda x: x["idx"])
    return poin


def klasifikasi_struktur(poin_swing):
    last_high = None
    last_low  = None
    for p in poin_swing:
        if p["tipe"] == "high":
            p["label"] = "H" if last_high is None else ("HH" if p["harga"] > last_high else "LH")
            last_high = p["harga"]
        else:
            p["label"] = "L" if last_low is None else ("HL" if p["harga"] > last_low else "LL")
            last_low = p["harga"]
    return poin_swing


def tentukan_bias(poin_label):
    highs = [p for p in poin_label if p["tipe"] == "high" and p["label"] in ("HH", "LH")]
    lows  = [p for p in poin_label if p["tipe"] == "low"  and p["label"] in ("HL", "LL")]
    if not highs or not lows:
        return "sideways", None, None
    lh, ll = highs[-1], lows[-1]
    if lh["label"] == "HH" and ll["label"] == "HL":
        return "bullish", lh, ll
    elif lh["label"] == "LH" and ll["label"] == "LL":
        return "bearish", lh, ll
    return "sideways", lh, ll


def bangun_zona_snr(df, bias, last_high, last_low):
    if bias == "sideways" or last_high is None or last_low is None:
        return None
    rh = df.loc[last_high["idx"]]
    rl = df.loc[last_low["idx"]]
    if bias == "bullish":
        return {"support": {"low": rl["low"], "high": rl["high"], "sumber": "HL"},
                "resistance": {"low": rh["low"], "high": rh["high"], "sumber": "HH"}}
    return {"support": {"low": rl["low"], "high": rl["high"], "sumber": "LL"},
            "resistance": {"low": rh["low"], "high": rh["high"], "sumber": "LH"}}


def deteksi_liquidity(poin_label, tolerance_pct=LIQUIDITY_TOLERANCE_PCT):
    def cari_cluster(lst):
        cluster, used = [], set()
        for i, a in enumerate(lst):
            if i in used: continue
            grup = [a]
            for j, b in enumerate(lst):
                if j <= i or j in used: continue
                if abs(a["harga"] - b["harga"]) / a["harga"] * 100 <= tolerance_pct:
                    grup.append(b); used.add(j)
            if len(grup) >= 2: cluster.append(grup)
        return cluster
    return (cari_cluster([p for p in poin_label if p["tipe"] == "high"]),
            cari_cluster([p for p in poin_label if p["tipe"] == "low"]))


def cari_order_block(df_entry, zona, bias, lookahead=4, min_impuls_pct=0.5):
    if zona is None or bias not in ("bullish", "bearish"): return None
    tz = zona["support"] if bias == "bullish" else zona["resistance"]
    zl, zh, kandidat = tz["low"], tz["high"], []
    for i in range(len(df_entry) - lookahead):
        row = df_entry.iloc[i]
        if row["high"] < zl or row["low"] > zh: continue
        if bias == "bullish" and row["close"] < row["open"]:
            w = df_entry.iloc[i+1:i+1+lookahead]
            if not w.empty:
                mc = w["close"].max()
                if mc > row["high"] and (mc - row["high"])/row["high"]*100 >= min_impuls_pct:
                    kandidat.append((i, row))
        elif bias == "bearish" and row["close"] > row["open"]:
            w = df_entry.iloc[i+1:i+1+lookahead]
            if not w.empty:
                mc = w["close"].min()
                if mc < row["low"] and (row["low"] - mc)/row["low"]*100 >= min_impuls_pct:
                    kandidat.append((i, row))
    if not kandidat: return None
    oi, ob = kandidat[-1]
    return {"idx_local": oi, "time": ob["timestamp"],
            "open": ob["open"], "high": ob["high"], "low": ob["low"], "close": ob["close"]}


def buat_sinyal(symbol, df_struktur, df_entry):
    df_s = deteksi_swing(df_struktur)
    poin = klasifikasi_struktur(ambil_urutan_swing(df_s))
    bias, last_high, last_low = tentukan_bias(poin)
    if bias == "sideways":
        return {"symbol": symbol, "status": "no_signal", "alasan": "Struktur 4H belum jelas (sideways/transisi)"}
    zona = bangun_zona_snr(df_s, bias, last_high, last_low)
    la, lb = deteksi_liquidity(poin)
    ob = cari_order_block(df_entry, zona, bias)
    if ob is None:
        return {"symbol": symbol, "status": "no_signal",
                "alasan": f"Bias {bias}, tapi belum ada Order Block valid di zona SNR (1H)"}
    buf = SL_BUFFER_PCT / 100
    if bias == "bullish":
        entry, sl, tp, arah = ob["high"], ob["low"]*(1-buf), zona["resistance"]["high"], "BUY"
    else:
        entry, sl, tp, arah = ob["low"], ob["high"]*(1+buf), zona["support"]["low"], "SELL"
    risiko = abs(entry - sl); reward = abs(tp - entry)
    rr = round(reward/risiko, 2) if risiko > 0 else 0
    return {"symbol": symbol, "status": "VALID" if rr >= MIN_RR else "RR_KURANG",
            "bias": bias, "arah": arah, "entry": round(entry,6), "sl": round(sl,6), "tp": round(tp,6), "rr": rr,
            "zona_support": zona["support"], "zona_resistance": zona["resistance"], "order_block": ob,
            "liquidity_atas_count": len(la), "liquidity_bawah_count": len(lb)}


