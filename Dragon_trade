def cek_konfigurasi():
    if GUNAKAN_TELEGRAM and (not TELEGRAM_BOT_TOKEN or not TELEGRAM_CHAT_ID):
        print("="*65)
        print("PERINGATAN: Telegram belum dikonfigurasi!")
        print("  export TELEGRAM_BOT_TOKEN='token_baru_kamu'")
        print("  export TELEGRAM_CHAT_ID='chat_id_kamu'")
        print("="*65)


def main():
    global BACKTEST_CANDLE_ENTRY_TOTAL
    parser = argparse.ArgumentParser(description="SNR Trading Signal Bot - Fixed Version")
    parser.add_argument("--once",             action="store_true")
    parser.add_argument("--backtest",         action="store_true")
    parser.add_argument("--backtest-candles", type=int, default=BACKTEST_CANDLE_ENTRY_TOTAL)
    args = parser.parse_args()
    cek_konfigurasi()
    exchange = getattr(ccxt, EXCHANGE_ID)({"enableRateLimit": True})
    if args.backtest:
        BACKTEST_CANDLE_ENTRY_TOTAL = args.backtest_candles
        jalankan_backtest(exchange); return
    if args.once:
        scan_sekali(exchange); return
    print(f"Bot SNR (Fixed) aktif. Scan setiap {INTERVAL_SCAN_DETIK//60} menit. CTRL+C untuk berhenti.")
    while True:
        try:
            scan_sekali(exchange)
        except KeyboardInterrupt:
            print("\nBot dihentikan."); sys.exit(0)
        except Exception as e:
            print(f"[!] Error: {e}")
        time.sleep(INTERVAL_SCAN_DETIK)


if __name__ == "__main__":
    main()
