def scan_sekali(exchange):
    print(f"\n===== SCAN {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')} =====")
    for symbol in SYMBOLS:
        try:
            df_struktur = ambil_ohlcv(exchange, symbol, TF_STRUKTUR, JUMLAH_CANDLE_STRUKTUR)
            df_entry    = ambil_ohlcv(exchange, symbol, TF_ENTRY, JUMLAH_CANDLE_ENTRY)
            sinyal = buat_sinyal(symbol, df_struktur, df_entry)
            print("-" * 60); print(format_sinyal(sinyal))
            if sinyal["status"] == "VALID":
                relevan, ket = validasi_entry_relevan(exchange, sinyal)
                print(f"  -> {ket}")
                if not relevan:
                    print("  -> Sinyal DILEWATI (entry terlewat)"); continue
                if sinyal_sudah_dikirim(sinyal):
                    print("  -> Sinyal DILEWATI (duplikat)"); continue
                if GUNAKAN_TERMUX_NOTIFICATION:
                    kirim_termux_notification(f"Sinyal {sinyal['arah']} {symbol}", format_sinyal(sinyal))
                if GUNAKAN_TELEGRAM:
                    kirim_telegram(format_sinyal(sinyal)); print("  -> Sinyal dikirim ke Telegram")
        except Exception as e:
            print(f"[!] Error saat proses {symbol}: {e}")


