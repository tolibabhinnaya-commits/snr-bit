def kirim_telegram(pesan):
    import urllib.request, urllib.parse
    if not TELEGRAM_BOT_TOKEN or not TELEGRAM_CHAT_ID:
        print("[!] TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID belum diset!")
        print("    Cara set: export TELEGRAM_BOT_TOKEN='token_kamu'")
        return
    url  = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
    data = urllib.parse.urlencode({"chat_id": TELEGRAM_CHAT_ID, "text": pesan, "parse_mode": "Markdown"}).encode()
    try:
        urllib.request.urlopen(url, data=data, timeout=10)
    except Exception as e:
        print(f"[!] Gagal kirim Telegram: {e}")


def format_sinyal(sinyal):
    if sinyal["status"] == "no_signal":
        return f"[{sinyal['symbol']}] Tidak ada sinyal. Alasan: {sinyal['alasan']}"
    emoji = "🟢" if sinyal["arah"] == "BUY" else "🔴"
    ket   = "VALID" if sinyal["status"] == "VALID" else "RR di bawah minimum"
    return (f"{emoji} SINYAL {sinyal['arah']} - {sinyal['symbol']} ({ket})\n"
            f"Bias 4H          : {sinyal['bias'].upper()}\n"
            f"Entry (OB)       : {sinyal['entry']}\n"
            f"Stop Loss        : {sinyal['sl']}\n"
            f"Take Profit      : {sinyal['tp']}\n"
            f"Risk:Reward      : 1:{sinyal['rr']}\n"
            f"Zona Support     : {sinyal['zona_support']['low']} - {sinyal['zona_support']['high']} ({sinyal['zona_support']['sumber']})\n"
            f"Zona Resistance  : {sinyal['zona_resistance']['low']} - {sinyal['zona_resistance']['high']} ({sinyal['zona_resistance']['sumber']})\n"
            f"Order Block      : O:{sinyal['order_block']['open']} H:{sinyal['order_block']['high']} L:{sinyal['order_block']['low']} C:{sinyal['order_block']['close']}\n"
            f"Liquidity pool   : {sinyal['liquidity_atas_count']} di atas, {sinyal['liquidity_bawah_count']} di bawah")


